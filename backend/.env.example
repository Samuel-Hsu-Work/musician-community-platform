# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://USER@localhost:5432/musictalks"

# JWT — use a long random string in production
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# CORS
FRONTEND_URL="http://localhost:3000"

# Cron (must match python-worker CRON_SECRET)
CRON_SECRET="change-me-cron-secret"

# OpenAI (optional locally; required for AI explanations + daily topics)
OPENAI_API_KEY=""

# Seed admin (optional — skip admin user if ADMIN_SEED_PASSWORD is unset)
ADMIN_SEED_EMAIL="admin@example.local"
ADMIN_SEED_USERNAME="Admin"
ADMIN_SEED_PASSWORD=""

# Promote an existing registered user to admin on seed (optional)
ADMIN_EMAIL=""

# Observability (optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT=development
LOGTAIL_SOURCE_TOKEN=""

# Forum insight pipeline (optional, default 3)
FORUM_INSIGHT_MIN_LIKES=3
